# Server
PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ENCRYPTION_KEY=your-encryption-key

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# BullMQ Redis (can be same as Upstash but needs ioredis-compatible URL)
REDIS_URL=rediss://default:token@your-redis.upstash.io:6379

# Yapily
YAPILY_APPLICATION_KEY=your-key
YAPILY_APPLICATION_SECRET=your-secret

# Plaid
PLAID_CLIENT_ID=your-client-id
PLAID_SECRET=your-secret
PLAID_ENV=sandbox
PLAID_REDIRECT_URI=
